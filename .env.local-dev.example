# Defaults note:
# - This file intentionally omits vars when code/scripts already provide the same defaults.
# - Runtime defaults are defined in apps/api/src/startup-validation.ts.
# - Script defaults are defined in scripts/local-env.sh, scripts/with-local-env.sh,
#   scripts/ollama-env.sh, and scripts/local-keycloak-setup.mjs.
# - Compose-substituted vars are kept explicit for docker workflows.

# Shared network name reused by local dev and runtime compose stacks.
MONET_SHARED_NETWORK=monet-shared

# PostgreSQL host bind for local machine access.
POSTGRES_DB=monet_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432
# Host-run commands derive DATABASE_URL from the POSTGRES_* values unless overridden.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/monet_local

# API host defaults to 0.0.0.0 in startup validation.
API_PORT=3301
# Optional override when agent MCP should point at a different public API origin.
# PUBLIC_API_URL=http://localhost:3301
# Optional override for an exact MCP endpoint.
# MCP_PUBLIC_URL=https://monet.example.com/mcp

# Dashboard host defaults to 0.0.0.0 in dashboard package scripts.
DASHBOARD_PORT=3310
NEXTAUTH_URL=http://localhost:3310
NEXTAUTH_SECRET=change-me-local-nextauth-secret
# Base64 encoding of exactly 32 bytes.
ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
# LOG_REQUESTS=true
# Only needed for seeded dashboard development mode.
DEV_BYPASS_AUTH=true
DASHBOARD_LOCAL_AUTH=true

# Local Keycloak host bind and bootstrap admin credentials.
KEYCLOAK_PORT=3400
PUBLIC_OIDC_BASE_URL=http://localhost:3400
LOCAL_OIDC_BASE_URL=http://localhost:3400
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Optional output path override for the local Keycloak bootstrap summary.
# LOCAL_KEYCLOAK_OUTPUT=.local-dev/keycloak.json

# For access from another machine, replace localhost with this machine's reachable
# IP or hostname in NEXTAUTH_URL, PUBLIC_API_URL, and PUBLIC_OIDC_BASE_URL.
# Keep KEYCLOAK_BASE_URL / LOCAL_OIDC_BASE_URL on an address the dashboard server
# itself can reach directly.

# Optional overrides for the Keycloak bootstrap script.
# KEYCLOAK_PLATFORM_REALM=monet
# KEYCLOAK_PLATFORM_CLIENT_ID=monet-platform
# KEYCLOAK_PLATFORM_ADMIN_EMAIL=platform-admin@example.com
# KEYCLOAK_PLATFORM_ADMIN_PASSWORD=MonetPlatform1!
# KEYCLOAK_TENANT_REALM=acme
# KEYCLOAK_TENANT_CLIENT_ID=monet-tenant
# KEYCLOAK_TENANT_ADMIN_EMAIL=tenant-admin@example.com
# KEYCLOAK_TENANT_ADMIN_PASSWORD=MonetTenantAdmin1!
# KEYCLOAK_TENANT_USER_EMAIL=tenant-user@example.com
# KEYCLOAK_TENANT_USER_PASSWORD=MonetTenantUser1!

# API runtime.
ENRICHMENT_CHAT_PROVIDER=ollama
ENRICHMENT_EMBEDDING_PROVIDER=onnx
# Optional when using hosted chat/embedding providers instead of Ollama.
# ENRICHMENT_CHAT_API_KEY=
# ENRICHMENT_EMBEDDING_API_KEY=
# Shared network endpoint for containerized runtime services.
OLLAMA_BASE_URL=http://ollama-shared:11434
# Host-run app processes use this when talking to local infrastructure.
# HOST_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Host Ollama model directory mounted into the container.
OLLAMA_MODELS_DIR=${HOME}/.ollama
# Recommended for Apple Silicon local quality/speed balance.
OLLAMA_CHAT_MODEL=qwen2.5:7b
# Must support 1536 output dimensions (Monet schema requirement).
OLLAMA_PORT=11434

# Optional defaults for local metrics scripts.
# LOCAL_TENANT_NAME=
# LOCAL_TENANT_ID=

# Local usage metrics output path.
# LOCAL_METRICS_OUTPUT=.local-dev/metrics.json
