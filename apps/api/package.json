{
  "name": "@monet/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:local": "tsx watch src/index.ts",
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:@xenova/transformers --outfile=dist/index.js --sourcemap",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests --fileParallelism=false",
    "test:unit": "vitest run --passWithNoTests --dir src",
    "test:integration": "vitest run --passWithNoTests --dir test --fileParallelism=false",
    "test:load:seed": "tsx test/load/seed.ts",
    "test:load": "k6 run test/load/k6-config.js"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@monet/db": "workspace:*",
    "@monet/mcp-tools": "workspace:*",
    "@monet/types": "workspace:*",
    "@xenova/transformers": "^2.17.0",
    "drizzle-orm": "^0.39.3",
    "hono": "^4",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.12",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
