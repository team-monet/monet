{
  "name": "@monet/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests --dir src",
    "test:integration": "vitest run --passWithNoTests --dir test --fileParallelism=false"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@monet/db": "workspace:*",
    "@monet/mcp-tools": "workspace:*",
    "@monet/types": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "hono": "^4",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
