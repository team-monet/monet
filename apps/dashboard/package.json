{
  "name": "@monet/dashboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "set -a; [ -f ../../.env ] && . ../../.env; set +a; sh -c 'dashboard_host=\"${DASHBOARD_HOST:-0.0.0.0}\"; next dev --hostname \"$dashboard_host\" --port \"${PORT:-3000}\"'",
    "dev:local": "sh -c 'dashboard_host=\"${DASHBOARD_HOST:-0.0.0.0}\"; next dev --hostname \"$dashboard_host\" --port \"${PORT:-3000}\"'",
    "dev:seeded": "./scripts/seed-and-start.sh",
    "build": "node ./scripts/build-with-retry.mjs",
    "start": "sh -c 'dashboard_host=\"${DASHBOARD_HOST:-${HOSTNAME:-0.0.0.0}}\"; next start --hostname \"$dashboard_host\" --port \"${PORT:-3000}\"'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@monet/db": "workspace:*",
    "@monet/types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.39.3",
    "lucide-react": "^0.577.0",
    "next": "^15",
    "next-auth": "5.0.0-beta.30",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.8",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7"
  }
}
