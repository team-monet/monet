# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monet

# Enrichment provider (anthropic | ollama | openai)
# "openai" works with any OpenAI-compatible API: OpenAI, Groq, Together,
# OpenRouter, vLLM, LM Studio, or Ollama via its /v1 endpoint.
ENRICHMENT_PROVIDER=openai
ENRICHMENT_API_KEY=

# OpenAI-compatible provider settings
# Use OPENAI_BASE_URL + OPENAI_API_KEY as defaults for both chat and embeddings,
# or override each independently with OPENAI_CHAT_* and OPENAI_EMBEDDING_*.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Split providers example (Google AI Studio for chat + local Ollama for embeddings):
# OPENAI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_CHAT_API_KEY=your-google-ai-studio-key
# OPENAI_CHAT_MODEL=gemini-2.0-flash-lite
# OPENAI_EMBEDDING_BASE_URL=http://localhost:11434/v1
# OPENAI_EMBEDDING_API_KEY=
# OPENAI_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Ollama (legacy — consider using openai with OPENAI_BASE_URL=http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434

# Dashboard auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# API
API_PORT=3001
NODE_ENV=development
# Base64 encoding of exactly 32 random bytes, e.g.:
# ENCRYPTION_KEY=$(openssl rand -base64 32)
ENCRYPTION_KEY=
