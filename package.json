{
  "name": "monet",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @monet/db migrate",
    "db:generate": "pnpm --filter @monet/db generate",
    "db:studio": "pnpm --filter @monet/db studio"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
