{
  "name": "monet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "TURBO_TELEMETRY_DISABLED=1 turbo dev",
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo build",
    "ci:local": "./scripts/ci-check.sh",
    "ci:quick": "MONET_CI_SKIP_IMAGES=1 ./scripts/ci-check.sh",
    "test": "TURBO_TELEMETRY_DISABLED=1 turbo test",
    "test:unit": "TURBO_TELEMETRY_DISABLED=1 turbo test:unit",
    "test:integration": "TURBO_TELEMETRY_DISABLED=1 turbo test:integration",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "TURBO_TELEMETRY_DISABLED=1 turbo lint",
    "prepare": "if [ -d .git ]; then git config core.hooksPath .githooks; fi",
    "typecheck": "TURBO_TELEMETRY_DISABLED=1 turbo typecheck",
    "db:migrate": "pnpm --filter @monet/db migrate",
    "db:generate": "pnpm --filter @monet/db generate",
    "db:studio": "pnpm --filter @monet/db studio",
    "local:up": "./scripts/local-env.sh up",
    "local:infra:up": "./scripts/local-env.sh up",
    "local:build": "./scripts/local-env.sh build",
    "local:migrate": "./scripts/local-env.sh migrate",
    "local:down": "./scripts/local-env.sh down",
    "local:infra:down": "./scripts/local-env.sh down",
    "local:status": "./scripts/local-env.sh status",
    "local:infra:status": "./scripts/local-env.sh status",
    "local:logs": "./scripts/local-env.sh logs",
    "local:infra:logs": "./scripts/local-env.sh logs",
    "local:db:reset": "./scripts/local-env.sh db-reset",
    "local:infra:db:reset": "./scripts/local-env.sh db-reset",
    "local:reset": "./scripts/local-env.sh reset",
    "local:infra:reset": "./scripts/local-env.sh reset",
    "local:dev:api": "./scripts/with-local-env.sh pnpm --filter @monet/api dev:local",
    "local:dev:dashboard": "./scripts/with-local-env.sh pnpm --filter @monet/dashboard dev:local",
    "local:mcp:smoke": "./scripts/local-env.sh mcp-smoke",
    "local:keycloak:setup": "./scripts/local-env.sh keycloak-setup",
    "local:metrics": "./scripts/local-env.sh metrics",
    "demo:support:seed": "pnpm --filter @monet/api exec tsx ../../scripts/demo/seed-support-workflow.ts",
    "demo:support:reset": "pnpm --filter @monet/api exec tsx ../../scripts/demo/reset-support-workflow.ts",
    "demo:support:smoke": "pnpm --filter @monet/api exec tsx ../../scripts/demo/smoke-support-workflow.ts",
    "runtime:up": "./scripts/runtime-env.sh up",
    "runtime:migrate": "./scripts/runtime-env.sh migrate",
    "runtime:down": "./scripts/runtime-env.sh down",
    "runtime:status": "./scripts/runtime-env.sh status",
    "runtime:logs": "./scripts/runtime-env.sh logs",
    "runtime:pull": "./scripts/runtime-env.sh pull",
    "runtime:keycloak:setup": "./scripts/runtime-env.sh keycloak-setup",
    "runtime:reset": "./scripts/runtime-env.sh reset",
    "ollama:up": "./scripts/ollama-env.sh up",
    "ollama:down": "./scripts/ollama-env.sh down",
    "ollama:status": "./scripts/ollama-env.sh status",
    "ollama:logs": "./scripts/ollama-env.sh logs"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "turbo": "^2",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
