{
  "name": "@team-monet/monet",
  "version": "0.3.0",
  "description": "Monet — local-first, state-centric memory for coding agents (MCP server): resolve-or-create dedup, contradiction detection, session-state survival, and query-independent prewarm.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": { "type": "git", "url": "git+https://github.com/team-monet/monet.git" },
  "homepage": "https://github.com/team-monet/monet",
  "keywords": ["mcp", "memory", "agent", "monet", "local-first", "state-centric", "embeddings"],
  "bin": {
    "monet": "./dist/cli.js"
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx watch src/cli.ts",
    "build": "node build.mjs",
    "build:cli": "node build.mjs cli",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --dir src",
    "prepack": "node build.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@team-monet/core": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^12.1.0",
    "zod": "^3.25.76",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.12",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
