{
  "name": "monet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @monet/db migrate",
    "db:generate": "pnpm --filter @monet/db generate",
    "db:studio": "pnpm --filter @monet/db studio",
    "local:up": "./scripts/local-env.sh up",
    "local:build": "./scripts/local-env.sh build",
    "local:migrate": "./scripts/local-env.sh migrate",
    "local:down": "./scripts/local-env.sh down",
    "local:status": "./scripts/local-env.sh status",
    "local:logs": "./scripts/local-env.sh logs",
    "local:db:reset": "./scripts/local-env.sh db-reset",
    "local:reset": "./scripts/local-env.sh reset",
    "local:mcp:smoke": "./scripts/local-env.sh mcp-smoke",
    "local:keycloak:setup": "./scripts/local-env.sh keycloak-setup",
    "local:metrics": "./scripts/local-env.sh metrics"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "turbo": "^2",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
