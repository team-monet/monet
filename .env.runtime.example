# Defaults note:
# - This file intentionally omits vars when code/scripts already provide the same defaults.
# - Runtime defaults are defined in apps/api/src/startup-validation.ts.
# - Script defaults are defined in scripts/runtime-env.sh, scripts/ollama-env.sh,
#   and scripts/local-keycloak-setup.mjs.
# - Compose-substituted vars are kept explicit for docker workflows.

# Shared network reused across local dev and runtime.
MONET_SHARED_NETWORK=monet-shared

# Image tags for the runtime stack. Override with your registry coordinates when needed.
API_IMAGE=monet-api:local
DASHBOARD_IMAGE=monet-dashboard:local
MIGRATE_IMAGE=monet-migrate:local
# Example GHCR coordinates for published releases:
# API_IMAGE=ghcr.io/team-monet/monet-api:v0.2.0
# DASHBOARD_IMAGE=ghcr.io/team-monet/monet-dashboard:v0.2.0
# MIGRATE_IMAGE=ghcr.io/team-monet/monet-migrate:v0.2.0

# PostgreSQL host bind for machine access.
POSTGRES_DB=monet_runtime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=65432

# API host bind.
API_PORT=4301
# Optional override when agents should connect to a different public API origin.
# In production, use an https:// public origin.
# PUBLIC_API_URL=http://localhost:4301
# Optional override for an exact public MCP endpoint.
# In production, use an https:// public endpoint ending in /mcp.
# MCP_PUBLIC_URL=https://monet.example.com/mcp

# Dashboard host bind.
DASHBOARD_PORT=4310
NEXTAUTH_URL=http://localhost:4310
NEXTAUTH_SECRET=change-me-runtime-nextauth-secret
# Base64 encoding of exactly 32 bytes. The example value is for local/runtime
# evaluation only; generate and rotate a real key for production.
ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
LOG_LEVEL=info
# LOG_REQUESTS=true
DEV_BYPASS_AUTH=false
DASHBOARD_LOCAL_AUTH=false

# Runtime Keycloak host bind and bootstrap admin credentials.
KEYCLOAK_PORT=4400
KEYCLOAK_BASE_URL=http://keycloak.localhost:4400
PUBLIC_OIDC_BASE_URL=http://keycloak.localhost:4400
LOCAL_OIDC_BASE_URL=http://keycloak.localhost:4400
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Optional output path override for the runtime Keycloak bootstrap summary.
# LOCAL_KEYCLOAK_OUTPUT=.runtime/keycloak.json

# For access from another machine, replace keycloak.localhost/localhost with this machine's reachable
# IP or hostname in NEXTAUTH_URL, PUBLIC_API_URL, and PUBLIC_OIDC_BASE_URL.
# In production behind a TLS proxy, NEXTAUTH_URL, PUBLIC_API_URL, MCP_PUBLIC_URL,
# and PUBLIC_OIDC_BASE_URL should all use https:// public origins.
# For a first internal trial on raw LAN ports, you can temporarily set
# ALLOW_INSECURE_PRIVATE_HTTP_ORIGINS=true and use http:// RFC1918/private-network
# IPs here instead. Browsers will treat those origins as insecure, and you should
# remove the flag before broader rollout.
# Keep KEYCLOAK_BASE_URL / LOCAL_OIDC_BASE_URL on the address the dashboard
# container uses to reach Keycloak internally. The runtime Compose stack uses
# PUBLIC_OIDC_BASE_URL as Keycloak's strict browser-facing hostname.
ALLOW_INSECURE_PRIVATE_HTTP_ORIGINS=false

# Runtime API configuration.
ENRICHMENT_CHAT_PROVIDER=none
ENRICHMENT_EMBEDDING_PROVIDER=onnx
# Optional when using hosted chat/embedding providers instead of Ollama.
# ENRICHMENT_CHAT_API_KEY=
# ENRICHMENT_EMBEDDING_API_KEY=
OLLAMA_BASE_URL=http://ollama-shared:11434
OLLAMA_MODELS_DIR=${HOME}/.ollama
OLLAMA_CHAT_MODEL=qwen2.5:3b
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
# ONNX embeddings (embedding provider only)
# Default model matches EMBEDDING_DIMENSIONS=1024.
# ONNX_EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
ONNX_QUANTIZED=true
OLLAMA_PORT=11434
# Embedding vector dimensions — must match your chosen embedding model (default: 1024).
EMBEDDING_DIMENSIONS=1024
AUDIT_RETENTION_DAYS=90
AUDIT_PURGE_ENABLED=false
# Optional restricted connection string for audit retention deletes.
# AUDIT_PURGE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:65432/monet_runtime
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# MCP session tuning. Defaults are suitable for most deployments.
# Per-request MCP timeout in milliseconds (default: 60000 = 60s).
# MCP_REQUEST_TIMEOUT_MS=60000
# Idle session TTL in milliseconds (default: 28800000 = 8h).
# Sessions with no activity for longer than this are swept automatically.
# MCP_SESSION_IDLE_TTL_MS=28800000
# Maximum concurrent MCP sessions per agent (default: 5).
# MCP_MAX_SESSIONS_PER_AGENT=5

# Optional runtime defaults.
LOCAL_TENANT_NAME=
