# Isolated compose project name for the long-running image-based stack.
MONET_RUNTIME_COMPOSE_PROJECT=monet-runtime
# Shared Ollama project and network reused across local dev and runtime.
MONET_OLLAMA_COMPOSE_PROJECT=monet-ollama
MONET_SHARED_NETWORK=monet-shared

# Image tags for the runtime stack. Override with your registry coordinates when needed.
API_IMAGE=monet-api:local
DASHBOARD_IMAGE=monet-dashboard:local
MIGRATE_IMAGE=monet-migrate:local

# PostgreSQL host bind for machine access.
POSTGRES_DB=monet_runtime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=65432

# API host bind.
API_PORT=4301
# Optional override when agents should connect to a different public API origin.
# PUBLIC_API_URL=http://localhost:4301
# Optional override for an exact public MCP endpoint.
# MCP_PUBLIC_URL=https://monet.example.com/mcp

# Dashboard host bind.
DASHBOARD_PORT=4310
NEXTAUTH_URL=http://localhost:4310
NEXTAUTH_SECRET=change-me-runtime-nextauth-secret
# Base64 encoding of exactly 32 bytes.
ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
DEV_BYPASS_AUTH=false
DASHBOARD_LOCAL_AUTH=false

# Runtime Keycloak host bind and bootstrap admin credentials.
KEYCLOAK_PORT=4400
KEYCLOAK_BASE_URL=http://keycloak.localhost:4400
LOCAL_OIDC_BASE_URL=http://keycloak.localhost:4400
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
LOCAL_KEYCLOAK_OUTPUT=.runtime/keycloak.json

# Runtime API configuration.
ENRICHMENT_PROVIDER=ollama
ENRICHMENT_API_KEY=
EMBEDDING_API_KEY=
OLLAMA_BASE_URL=http://ollama-shared:11434
OLLAMA_MODELS_DIR=${HOME}/.ollama
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
OLLAMA_PORT=11434
AUDIT_RETENTION_DAYS=90
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Optional runtime defaults.
LOCAL_TENANT_NAME=
