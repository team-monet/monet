#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

export MONET_CI_SKIP_IMAGES="${MONET_CI_SKIP_IMAGES:-1}"

if [[ "${MONET_CI_SKIP_IMAGES}" == "1" ]]; then
  echo "Running Monet CI guard before push (skipping image builds by default)..."
else
  echo "Running Monet CI guard before push..."
fi

pnpm ci:local
